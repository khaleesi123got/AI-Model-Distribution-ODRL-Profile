@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix dcat: <https://www.w3.org/ns/dcat#> .
@prefix cc:   <http://creativecommons.org/ns#> .
@prefix airo: <https://w3id.org/airo#> .
@prefix aimd: <https://raw.githubusercontent.com/ci2me/AI-Model-Distribution-ODRL-Profile/main/AIMD.ttl#> .

# ─────────────────────────────────────────────────────────────────────────────
#  OpenAccessAcademicLicence
#  ODRL Policy to be attached (via dct:license / odrl:hasPolicy) to a
#  dcat:Dataset / aimd:ResearchProduct published in an institutional repository
#  (e.g. TCD TARA, Zenodo).
#
#  Any organisation that uses the resource to train an AI model MUST satisfy
#  the obligations below before releasing the resulting model.
# ─────────────────────────────────────────────────────────────────────────────

<https://example.com/policy/OpenAccessAcademicLicence>
    a odrl:Policy, odrl:Set ;
    dct:title "Open Access Academic Research Licence for AI Training" ;
    dct:description "Permits use of open-access academic research outputs for AI model training, subject to attribution, openness, documentation, and compliance reporting obligations aligned with the EU AI Act and GPAI rules." ;
    dct:created "2026-02-25"^^xsd:date ;
    dct:creator <https://example.com/TCD-TARA> ;

    # ── PERMISSION block ──────────────────────────────────────────────────────
    odrl:permission [
        odrl:target  <https://example.com/AcademicRepository/ResearchOutputs> ;
        odrl:assigner <https://example.com/TCD-TARA> ;

        # Permitted actions
        odrl:action odrl:use ;
        odrl:action odrl:reproduce ;
        odrl:action odrl:derive ;
        odrl:action cc:ShareAlike ;

        # ── Forbidden purposes (AI Act Art. 5 prohibited uses) ────────────────
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:SocialScoring ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:RemoteBiometricIdentification ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:BiometricCategorisation ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:Manipulation ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:VulnerableExploitation ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:AssessCrimeLikelihood ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:FacialDataScraping ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  airo:Purpose ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:EmotionInference ;
        ] ;

        # Same forbidden purposes for any derivative model
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:SocialScoring ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:RemoteBiometricIdentification ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:BiometricCategorisation ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:Manipulation ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:VulnerableExploitation ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:AssessCrimeLikelihood ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:FacialDataScraping ;
        ] ;
        odrl:constraint [
            odrl:leftOperand  aimd:PurposeOfDerivation ;
            odrl:operator     odrl:neq ;
            odrl:rightOperand aimd:EmotionInference ;
        ] ;

        # ── Obligations: what the downstream AI developer MUST publish ─────────
        odrl:obligation [
            odrl:action
                aimd:AttributeTrainingSources ,      # cite all DOIs / repos used
                aimd:PublishModelCard ,              # Hugging Face-style model card
                aimd:PublishDatasetCard ,            # dataset card listing all training sets
                aimd:DocumentTrainingData ,          # detailed training data summary
                aimd:DiscloseCO2Emissions ,          # energy / CO2 disclosure
                aimd:PublishBiasReport ,             # bias evaluation report
                aimd:PublishSummaryOfCapabilities ,  # GPAI capability summary (AI Act Art. 53)
                aimd:ImplementCopyrightPolicy ,      # copyright opt-out compliance
                aimd:AssessModelRisk ,               # risk assessment
                aimd:ProvideTechDocumentation ,      # technical documentation
                aimd:EnsureDataProtection ,          # GDPR compliance
                aimd:MakeModelOpenAccess ,           # share-alike: release model openly
                aimd:LinkToSourceLicences ,          # machine-readable links to source ODRL policies
                aimd:RegisterWithSourceRepo ,        # notify / register with source repository
                aimd:UploadDerivations ,             # upload derivative to owner's DB
                aimd:UploadUseOfDerivation ;         # upload usage record
        ] ;
    ] .
